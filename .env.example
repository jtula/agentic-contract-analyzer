# ════════════════════════════════════════════════
# CONTRACT RISK ANALYZER — Environment Variables
# ════════════════════════════════════════════════
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ── LLM Provider ─────────────────────────────────
LLM_PROVIDER=openai             # openai | bedrock
OPENAI_API_KEY=sk-...           # Required when LLM_PROVIDER=openai
OPENAI_MODEL=gpt-4o             # gpt-4o | gpt-4o-mini
LLM_TEMPERATURE=0.1             # Low temperature for legal analysis

# ── AWS (use LocalStack values for local dev) ─────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=test          # LocalStack accepts any value
AWS_SECRET_ACCESS_KEY=test      # LocalStack accepts any value
AWS_ENDPOINT_URL=http://localhost:4566  # Remove for real AWS

S3_BUCKET_NAME=contract-analyzer-docs
DYNAMODB_TABLE_NAME=contract-analyzer-runs

# ── LangSmith Observability ───────────────────────
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=ls__...       # Get at smith.langchain.com
LANGCHAIN_PROJECT=contract-risk-analyzer

# ── Application ───────────────────────────────────
LOG_LEVEL=INFO                  # DEBUG | INFO | WARNING | ERROR
CONFIDENCE_THRESHOLD=0.75       # Below this → HITL gate triggers
MAX_FILE_SIZE_MB=10
ALLOWED_ORIGINS=*               # Restrict in production

# ── Bedrock (only when LLM_PROVIDER=bedrock) ──────
# BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0

# ── API Security ────────────────────────────────
# API_KEY=change-me-in-production   # When set, all endpoints require X-API-Key header
